# Database
DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_db"

# Auth
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=4000
NODE_ENV="development"
APP_NAME="Restaurant Management"
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Email (Resend)
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="noreply@yourdomain.com"

# Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# Feature Flags (overridden by config/client.json injection)
FEATURE_ONLINE_ORDERING="false"
FEATURE_DELIVERY_MANAGEMENT="false"
FEATURE_TABLE_RESERVATIONS="false"
FEATURE_KITCHEN_DISPLAY="false"
FEATURE_POS_INTEGRATION="false"
FEATURE_INVENTORY_MANAGEMENT="false"
FEATURE_LOYALTY_PROGRAM="false"
FEATURE_QR_MENU="false"
FEATURE_SMS_NOTIFICATIONS="false"
FEATURE_WHATSAPP_AUTOMATION="false"
FEATURE_AI_CHATBOT="false"
FEATURE_ADVANCED_ANALYTICS="false"
